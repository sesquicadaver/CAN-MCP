{
  "name": "codimension-vscode",
  "displayName": "Codimension Analysis",
  "description": "VS Code companion for Codimension MCP code analysis",
  "version": "0.5.0",
  "publisher": "codimension",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codimension.showDiagram",
    "onCommand:codimension.openMcpDocs",
    "onCommand:codimension.copyMcpConfig",
    "onCommand:codimension.showMcpResources",
    "workspaceContains:.codimension/diagrams"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Codimension",
      "properties": {
        "codimension.autoOpenDiagrams": {
          "type": "boolean",
          "default": true,
          "description": "Open a WebView when MCP render_diagram writes HTML under .codimension/diagrams/"
        }
      }
    },
    "commands": [
      {
        "command": "codimension.openMcpDocs",
        "title": "Codimension: Open MCP Setup Guide"
      },
      {
        "command": "codimension.copyMcpConfig",
        "title": "Codimension: Copy MCP Server Config"
      },
      {
        "command": "codimension.showMcpResources",
        "title": "Codimension: List MCP Resource URIs"
      },
      {
        "command": "codimension.showDiagram",
        "title": "Codimension: Show Diagram (HTML WebView)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
